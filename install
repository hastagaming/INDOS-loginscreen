#!/bin/bash

# --- Warna untuk Output ---
BLUE='\e[1;34m'
GREEN='\e[1;32m'
YELLOW='\e[1;33m'
CYAN='\e[1;36m'
NC='\e[0m' # No Color

clear
echo -e "${BLUE}󰣇  INDOS SYSTEM INSTALLER${NC}"
echo -e "${CYAN}----------------------------------${NC}"

# 1. Deteksi Direktori
# Mengambil path absolut tempat installer dijalankan
INSTALL_DIR=$(pwd)

# 2. Instalasi Dependensi
echo -e "${YELLOW}[*] Updating system & installing dependencies...${NC}"
pkg update && pkg upgrade -y
pkg install python -y

echo -e "${YELLOW}[*] Installing Python libraries...${NC}"
pip install textual

# 3. Membuat perintah 'indos' di sistem
echo -e "${YELLOW}[*] Registering 'indos' command to system...${NC}"

# Membuat script launcher di folder bin Termux
cat <<EOF > indos
#!/bin/bash
# INDOS Launcher
python $INSTALL_DIR/core/main.py
EOF

# Memberikan izin eksekusi pada launcher
chmod +x indos

# Memindahkan ke folder bin agar bisa dipanggil dari mana saja
mv indos $PREFIX/bin/

# 4. Memastikan izin folder core
chmod +x $INSTALL_DIR/core/main.py
chmod +x $INSTALL_DIR/core/utils.py

echo -e "${CYAN}----------------------------------${NC}"
echo -e "${GREEN}[+] SUCCESS: INDOS has been installed!${NC}"
echo -e "${BLUE}[!] You can now start the system by typing:${NC} ${YELLOW}indos${NC}"
echo -e "${CYAN}----------------------------------${NC}"
